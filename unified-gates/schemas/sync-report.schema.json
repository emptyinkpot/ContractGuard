{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contractguard/unified-gates/schemas/sync-report.schema.json",
  "title": "Unified Gates Sync Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "ok",
    "schemaVersion",
    "mode",
    "masterControlPath",
    "gateRegistryPath",
    "policyMapPath",
    "derivedDate",
    "currentMode",
    "counts",
    "derivedGroups",
    "artifacts",
    "preview",
    "pathExistenceValidation",
    "policyArtifactValidation"
  ],
  "properties": {
    "ok": {
      "type": "boolean",
      "const": true
    },
    "schemaVersion": {
      "type": "string",
      "const": "1.0.0"
    },
    "mode": {
      "type": "string",
      "enum": ["write", "dry-run", "report"]
    },
    "masterControlPath": {
      "type": "string",
      "minLength": 1
    },
    "gateRegistryPath": {
      "type": "string",
      "minLength": 1
    },
    "policyMapPath": {
      "type": "string",
      "minLength": 1
    },
    "derivedDate": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "currentMode": {
      "type": ["string", "null"]
    },
    "counts": {
      "$ref": "#/$defs/counts"
    },
    "derivedGroups": {
      "$ref": "#/$defs/derivedGroups"
    },
    "artifacts": {
      "$ref": "#/$defs/artifacts"
    },
    "preview": {
      "$ref": "#/$defs/preview"
    },
    "pathExistenceValidation": {
      "$ref": "#/$defs/pathExistenceValidation"
    },
    "policyArtifactValidation": {
      "$ref": "#/$defs/policyArtifactValidation"
    }
  },
  "$defs": {
    "counts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "generatedGates",
        "preservedGates",
        "totalBefore",
        "totalAfter"
      ],
      "properties": {
        "generatedGates": {
          "type": "integer",
          "minimum": 0
        },
        "preservedGates": {
          "type": "integer",
          "minimum": 0
        },
        "totalBefore": {
          "type": "integer",
          "minimum": 0
        },
        "totalAfter": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "derivedGroups": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "executionGates",
        "commitRules",
        "pushRules",
        "verifyRules",
        "deployRules"
      ],
      "properties": {
        "executionGates": {
          "$ref": "#/$defs/gateIdArray"
        },
        "commitRules": {
          "$ref": "#/$defs/gateIdArray"
        },
        "pushRules": {
          "$ref": "#/$defs/gateIdArray"
        },
        "verifyRules": {
          "$ref": "#/$defs/gateIdArray"
        },
        "deployRules": {
          "$ref": "#/$defs/gateIdArray"
        }
      }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "masterControlSha256",
        "executionGatesSha256",
        "ruleSources"
      ],
      "properties": {
        "masterControlSha256": {
          "$ref": "#/$defs/sha256"
        },
        "executionGatesSha256": {
          "$ref": "#/$defs/sha256"
        },
        "ruleSources": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "preview": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "gateRegistry",
        "policyMap"
      ],
      "properties": {
        "gateRegistry": {
          "$ref": "#/$defs/previewEntry"
        },
        "policyMap": {
          "$ref": "#/$defs/previewEntry"
        }
      }
    },
    "previewEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "beforeBytes",
        "afterBytes",
        "changed"
      ],
      "properties": {
        "beforeBytes": {
          "type": "integer",
          "minimum": 0
        },
        "afterBytes": {
          "type": "integer",
          "minimum": 0
        },
        "changed": {
          "type": "boolean"
        }
      }
    },
    "policyArtifactValidation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "gateRegistry",
        "policyMap"
      ],
      "properties": {
        "gateRegistry": {
          "$ref": "#/$defs/validationResult"
        },
        "policyMap": {
          "$ref": "#/$defs/validationResult"
        }
      }
    },
    "pathExistenceValidation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ok",
        "checkedTargets",
        "missingTargets"
      ],
      "properties": {
        "ok": {
          "type": "boolean"
        },
        "checkedTargets": {
          "type": "integer",
          "minimum": 0
        },
        "missingTargets": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["kind", "source", "target"],
            "properties": {
              "kind": { "type": "string", "minLength": 1 },
              "source": { "type": "string", "minLength": 1 },
              "target": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    },
    "validationResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ok",
        "errors"
      ],
      "properties": {
        "ok": {
          "type": "boolean"
        },
        "errors": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "gateIdArray": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^GATE-[A-Z0-9-]+$"
      }
    },
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    }
  }
}
