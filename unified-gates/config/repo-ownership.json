  "default_rules": {
    "owning_repo_first": true,
    "umbrella_repo_second": true,
    "mirror_repo_last": true,
    "github_is_source_of_truth": true,
    "server_is_deploy_target_only": true
  },

  "sync_strategy": {
    "description": "先在 owning repo 完成 status -> commit -> push，再同步到 umbrella repo",
    "order": [
      "owning repo (sync_order=1)",
      "umbrella repo (sync_order=2)",
      "mirror/backup repo (sync_order=3)"
    ]
  },

  "comments": {
    "extracted_from": "C:\\Users\\ASUS-KL\\.codex\\REPO-OWNERSHIP-MAP.md",
    "key_rules": [
      "对 repo-managed code，GitHub 中 owning repo 是唯一长期 source of truth",
      "不要默认在 deploy server 上并行维护源码",
      "先按 repo role + change boundary 判断，不按仓大/仓小或路径远近判断"
    ]
  }
