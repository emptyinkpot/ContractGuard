{
  "$schema": "../schemas/github-delivery-policy.schema.json",
  "version": "1.0.0",
  "last_updated": "2026-04-26T00:00:00Z",

  "auto_push": {
    "enabled": true,
    "description": "repo-managed work 结束后自动推送",
    "conditions": {
      "require_remote_configured": true,
      "require_changes_verified": true,
      "skip_if_blocked": true,
      "check_branch_state": true
    },
    "exceptions": {
      "paths": [
        "C:\\Users\\ASUS-KL\\.codex\\.tmp\\*",
        "**/node_modules/**",
        "**/.git/**"
      ],
      "repos": []
    }
  },

  "delivery_state_requirement": {
    "enabled": true,
    "description": "repo-managed work 必须明确 delivery state",
    "valid_states": ["pushed", "local-only by request", "not-needed", "blocked"],
    "default_state": "pushed",
    "require_reason_if_not_pushed": true
  },

  "commit_behavior": {
    "auto_stage_changes": true,
    "require_commit_message": true,
    "commit_message_template": "{type}({scope}): {description}\n\nCo-Authored-By: {agent_name} <noreply@anthropic.com>",
    "allowed_commit_types": ["feat", "fix", "docs", "refactor", "test", "chore", "style", "perf"],
    "verify_no_conflicts": true
  },

  "push_behavior": {
    "default_push": true,
    "push_to_remote": "origin",
    "push_branch": "current",
    "force_push_allowed": false,
    "verify_before_push": true,
    "check_ahead_behind": true,
    "fail_if_behind": true
  },

  "pr_behavior": {
    "auto_create_pr": false,
    "pr_on_feature_branch": true,
    "pr_template_path": null,
    "pr_title_template": "{type}: {description}",
    "pr_body_template": "## Summary\n{summary}\n\n## Changes\n{changes}\n\n🤖 Generated by {agent_name}"
  },

  "allowed_roots": [
    "C:\\Users\\ASUS-KL\\.codex",
    "E:\\My Project"
  ],

  "ownership_map_path": "../config/repo-ownership.json",
  "working_copy_root": "C:\\Users\\ASUS-KL\\.codex\\.tmp\\working-copies",

  "source_of_truth": {
    "description": "GitHub 中 owning repo 是唯一长期 source of truth",
    "prefer_github_over_server": true,
    "server_is_deploy_target_only": true
  },

  "comments": {
    "extracted_from": [
      "C:\\Users\\ASUS-KL\\.codex\\AGENTS.md - Git And Repo Boundary",
      "E:\\My Project\\Atramenti-Console\\codex\\mcps\\github-delivery-mcp\\server.mjs"
    ],
    "key_rules": [
      "repo-managed work 结束前必须明确 delivery state",
      "对已配置 push remote 的工作，要么 commit + push，要么说明原因",
      "不要把 push 说成 deployed，除非真的运行了 deploy"
    ]
  }
}
