{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contractguard.local/schemas/decision.schema.json",
  "title": "ContractGuard Decision Result",
  "type": "object",
  "required": ["decision", "gateId", "reason", "violations"],
  "properties": {
    "decision": {
      "type": "string",
      "enum": ["allow", "review", "block"]
    },
    "gateId": {
      "type": "string",
      "minLength": 1
    },
    "reason": {
      "type": "string",
      "minLength": 1
    },
    "violations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code", "severity", "detail"],
        "properties": {
          "code": {
            "type": "string",
            "minLength": 1
          },
          "severity": {
            "type": "string",
            "minLength": 1
          },
          "detail": {
            "type": "string",
            "minLength": 1
          },
          "category": {
            "type": "string"
          },
          "source": {
            "type": "string"
          },
          "evidence": {
            "type": "array"
          }
        },
        "additionalProperties": true
      }
    },
    "status": {
      "type": "string"
    },
    "tool": {
      "type": "string"
    },
    "ok": {
      "type": "boolean"
    },
    "verdict": {
      "type": "string"
    },
    "timestampUtc": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
